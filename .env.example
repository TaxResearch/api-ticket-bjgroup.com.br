# Copie para .env e preencha os valores
# cp .env.example .env

# --- Banco de dados (externo) ---
DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=DevDeck
DATABASE_URL=mysql://user:password@host:3306/DevDeck

# --- API ---
PORT=3099

# --- E-mail (SMTP) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM='"BJGROUP Suporte" <noreply@example.com>'

# --- Segurança ---
ENCRYPTION_SECRET_KEY=
JWT_SECRET=

# --- Pusher ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2
