# Copie para .env e preencha os valores
# cp .env.example .env

# --- Banco de dados ---
# Stack Docker (--profile with-db): use host "mysql"
# Banco externo: use o IP/hostname real
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_USER=ticket
DATABASE_PASSWORD=ticket
DATABASE_NAME=DevDeck
DATABASE_URL=mysql://ticket:ticket@mysql:3306/DevDeck

# MySQL no Docker (profile with-db)
MYSQL_ROOT_PASSWORD=root
MYSQL_PUBLISH_PORT=3307

# --- API ---
PORT=3001

# --- E-mail (SMTP) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM='"BJGROUP Suporte" <noreply@example.com>'

# --- Segurança ---
ENCRYPTION_SECRET_KEY=
JWT_SECRET=

# --- Pusher ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2
